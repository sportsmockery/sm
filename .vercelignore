# Vercel deploy ignore list — keeps the upload tarball lean.
# .gitignore-style; trailing slashes can be unreliable for hidden dirs,
# so paths are listed both bare and with trailing-slash where useful.

# ── VCS / agent directories (HIDDEN — most aggressive entries first) ─────
.git
.git/
.github
.github/
.claude
.claude/
.claude-code
.claude-code/

# ── Build artifacts (Vercel rebuilds these from source) ─────────────────
.next
.next/
out
out/
build
build/
dist
dist/
.turbo
.turbo/
.cache
.cache/
.tsbuildinfo
tsconfig.tsbuildinfo

# ── Native / non-web subprojects (not consumed by the Next.js app) ──────
mobile
mobile/
postiq-test-venv
postiq-test-venv/
.venv
.venv/
venv
venv/

# ── Local docs / screenshots / PDFs that bloat the tarball ──────────────
screenshots
screenshots/
docs
docs/
*.pdf
*.rtf
edge-email-preview.png

# ── IDE / OS / local caches ─────────────────────────────────────────────
.idea
.idea/
.vscode
.vscode/
.DS_Store

# ── Test / coverage / logs ──────────────────────────────────────────────
coverage
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local env (Vercel injects its own at runtime) ───────────────────────
.env.local
.env.vercel-check

# ── Sub-projects that ship their own deploy (sm-data-lab etc.) ──────────
sm-data-lab
sm-data-lab/
