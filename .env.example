# Canonical site URL — drives sitemap.xml, robots.txt, canonical tags, etc.
# MUST be set per Vercel environment:
#   Production:        https://sportsmockery.com
#   Preview/Staging:   https://test.sportsmockery.com   (or the preview URL)
#   Local dev:         http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Figma Design Sync
FIGMA_TOKEN=
FIGMA_FILE_KEY=

# DataLab Supabase (sports data backend)
DATALAB_SUPABASE_URL=
DATALAB_SUPABASE_ANON_KEY=
DATALAB_SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limiting — required for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
