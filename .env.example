# Figma Design Sync
FIGMA_TOKEN=
FIGMA_FILE_KEY=

# DataLab Supabase (sports data backend)
DATALAB_SUPABASE_URL=
DATALAB_SUPABASE_ANON_KEY=
DATALAB_SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (rate limiting — required for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostIQ — DataLab AI/PostIQ proxy (auto-link, suggest, charts)
# POSTIQ_BASE_URL defaults to DATALAB_API_URL when unset.
POSTIQ_BASE_URL=https://datalab.sportsmockery.com
POSTIQ_INTERNAL_KEY=

# Cloudflare Turnstile — required once Supabase Auth's CAPTCHA toggle is
# enabled. The widget renders on signup / login / forgot-password and the
# token is forwarded to Supabase via `options.captchaToken`.
#
# When this var is unset the auth forms render WITHOUT the widget so dev /
# preview environments keep working. As soon as the value is populated,
# the widget appears and submits are blocked until a token is produced —
# so set this in lockstep with enabling Turnstile in the Supabase dashboard.
#
# Site key (public, safe to expose):  Cloudflare → Turnstile → Site → Site key
# Secret key (NEVER commit, paste into Supabase dashboard, not here):
#   Cloudflare → Turnstile → Site → Secret key → Supabase → Auth → Settings →
#   Bot and Abuse Protection → Add CAPTCHA provider → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
