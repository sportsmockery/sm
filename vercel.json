{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next",
      "config": {
        "installCommand": "npm ci --prefer-offline"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-teams",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/team-pages-health",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/sync-bears-data",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/live-games",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/send-chicago-daily",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup-scout-history",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-gm-rosters",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/cron/audit-gm",
      "schedule": "50 * * * *"
    },
    {
      "path": "/api/cron/mobile-alerts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/audit-orbs",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/sync-wordpress",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sync-writer-views",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/sync-article-views",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-article-comments",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/scout-prompts",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.+\\.(?:ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot)$)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
