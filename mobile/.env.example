# Sports Mockery Mobile App Environment Variables
# Copy this file to .env and fill in your values

# Supabase (same as web app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OneSignal Push Notifications
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# API Base URL (for development, use your local or staging URL)
# Production will use https://sportsmockery.com
EXPO_PUBLIC_API_URL=https://test.sportsmockery.com
